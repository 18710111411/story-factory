# AI Video Creator Agent - 环境变量配置
# 复制此文件为 .env 并填入真实 API Keys

# === API Keys ===
MUAPI_API_KEY=your_muapi_key_here
JIMENG_API_KEY=your_jimeng_key_here
VIDEO_API_KEY=your_video_api_key_here

# === 路径配置 ===
PROJECT_DIR=/home/admin/.openclaw/workspace/projects
AGENT_DIR=/home/admin/.openclaw/workspace/agents/ai-video-creator
LOG_DIR=$AGENT_DIR/logs

# === 运行配置 ===
LOG_LEVEL=info
DEFAULT_MODEL=kling
DEFAULT_RESOLUTION=1080x1920
DEFAULT_FPS=24

# === 通知配置 (可选) ===
# WEBHOOK_ON_COMPLETE=http://localhost:18955/webhook/video-done
# WEBHOOK_ON_ERROR=http://localhost:18955/webhook/video-error

# === 会话配置 ===
# MAIN_SESSION_LABEL=main
# NOTIFY_ON_COMPLETE=true
